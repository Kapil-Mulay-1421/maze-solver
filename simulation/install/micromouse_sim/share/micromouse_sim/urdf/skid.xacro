<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"  name="robot">

    <xacro:include filename="inertial_macros.xacro"/>

    <material name="white">
        <color rgba="1 1 1 1" />
    </material> 

    <material name="orange">
        <color rgba="1 0.3 0.1 1" />
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1" />
    </material>

    <material name="black">
        <color rgba="0 0 0 1" />
    </material>

    <material name="red">
        <color rgba="1 0 0 1" />
    </material>

    <!-- Example link -->
    <link name="base_link">
    </link>

    <!-- CHASSIS LINK-->
    <joint name="chassis_joint" type="fixed">
        <parent link= "base_link"/>
        <child link="chassis"/>
        <origin xyz="0 0 0"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <box size="0.111 0.065 0.028"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.111 0.065 0.028"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.111" y="0.065" z="0.028">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>  
    </link>

    <gazebo reference="chassis">
        <material>Gazebo/White</material>
    </gazebo>

    <!--FORWARD_LEFT LINK-->
    <joint name="front_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="front_left_wheel"/>
        <origin xyz="0.0265 0.046 0" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="front_left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.0245" length="0.02"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.0245" length="0.02"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.02" radius="0.0245">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="front_left_wheel">
        <material>Gazebo/Blue</material>
        <surface>
          <friction>
            <ode>
              <mu>10.0</mu>
              <mu2>10.0</mu2>
            </ode>
          </friction>
        </surface>
    </gazebo>

    <!--FORWARD_RIGHT LINK-->
    <joint name="front_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="front_rear_wheel"/>
        <origin xyz="0.026 -0.046 0" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="front_rear_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.0245" length="0.02"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.0245" length="0.02"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.02" radius="0.0245">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>
    <gazebo reference="front_rear_wheel">
        <material>Gazebo/Blue</material>
        <surface>
          <friction>
            <ode>
              <mu>10.0</mu>
              <mu2>10.0</mu2>
            </ode>
          </friction>
        </surface>
    </gazebo>

    <!--BACK_LEFT LINK-->
    <joint name="back_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="back_left_wheel"/>
        <origin xyz="-0.026 0.046 0" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="back_left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.0245" length="0.02"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.0245" length="0.02"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.02" radius="0.0245">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>
    <gazebo reference="back_left_wheel">
        <surface>
          <friction>
            <ode>
              <mu>10.0</mu>
              <mu2>10.0</mu2>
            </ode>
          </friction>
        </surface>
    </gazebo>

    <!--BACK_RIGHT LINK-->
    <joint name="back_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="back_right_wheel"/>
        <origin xyz="-0.026 -0.046 0" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="back_right_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.0245" length="0.02"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.0245" length="0.02"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.02" radius="0.0245">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="back_right_wheel">
        <surface>
          <friction>
            <ode>
              <mu>10.0</mu>
              <mu2>10.0</mu2>
            </ode>
          </friction>
        </surface>
    </gazebo>

   <!-- ToF Sensor - Forward -->
<link name="tof_sensor_front_link">
  <visual>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <geometry><cylinder radius="0.005" length="0.01"/></geometry>
    <material name="black"/>
  </visual>
  <collision>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <geometry><cylinder radius="0.005" length="0.01"/></geometry>
  </collision>
  <inertial>
    <mass value="0.01"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
  </inertial>
</link>

<joint name="tof_sensor_front_joint" type="fixed">
  <parent link="base_link"/>
  <child link="tof_sensor_front_link"/>
  <origin xyz="0.055 0 0.03" rpy="0 0 0"/>
</joint>

<gazebo reference="tof_sensor_front_link">
  <sensor name="tof_front" type="ray">
    <pose>0.03 0 0 0 0 0</pose>
    <visualize>true</visualize>
    <update_rate>10</update_rate>
    <ray>
      <scan>
        <horizontal>
          <samples>1</samples>
          <resolution>1</resolution>
          <min_angle>0</min_angle>
          <max_angle>0</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.01</min>
        <max>2.0</max>
        <resolution>0.01</resolution>
      </range>
    </ray>
    <plugin name="gazebo_ros_ray_sensor" filename="libgazebo_ros_ray_sensor.so">
      <ros><argument>~/out:=tof_front</argument></ros>
      <output_type>sensor_msgs/LaserScan</output_type>
      <frame_name>tof_sensor_front_link</frame_name>
    </plugin>
  </sensor>
</gazebo>

<!-- ToF Sensor - Left 45° -->
<link name="tof_sensor_left_link">
  <visual>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <geometry><cylinder radius="0.005" length="0.01"/></geometry>
    <material name="black"/>
  </visual>
  <collision>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <geometry><cylinder radius="0.005" length="0.01"/></geometry>
  </collision>
  <inertial>
    <mass value="0.01"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
  </inertial>
</link>

<joint name="tof_sensor_left_joint" type="fixed">
  <parent link="base_link"/>
  <child link="tof_sensor_left_link"/>
  <origin xyz="0.055 0 0.03" rpy="0 0 0.57004"/> <!-- 0.7854 rad ≈ 45° -->
</joint>

<gazebo reference="tof_sensor_left_link">
  <sensor name="tof_left" type="ray">
    <pose>0.03 0 0 0 0 0</pose>
    <visualize>true</visualize>
    <update_rate>10</update_rate>
    <ray>
      <scan>
        <horizontal>
          <samples>1</samples>
          <resolution>1</resolution>
          <min_angle>0</min_angle>
          <max_angle>0</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.01</min>
        <max>2.0</max>
        <resolution>0.01</resolution>
      </range>
    </ray>
    <plugin name="gazebo_ros_ray_sensor_left" filename="libgazebo_ros_ray_sensor.so">
      <ros><argument>~/out:=tof_left</argument></ros>
      <output_type>sensor_msgs/LaserScan</output_type>
      <frame_name>tof_sensor_left_link</frame_name>
    </plugin>
  </sensor>
</gazebo>


<!-- ToF Sensor - Right 45° -->
<link name="tof_sensor_right_link">
  <visual>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <geometry><cylinder radius="0.005" length="0.01"/></geometry>
    <material name="black"/>
  </visual>
  <collision>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <geometry><cylinder radius="0.005" length="0.01"/></geometry>
  </collision>
  <inertial>
    <mass value="0.01"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
  </inertial>
</link>

<joint name="tof_sensor_right_joint" type="fixed">
  <parent link="base_link"/>
  <child link="tof_sensor_right_link"/>
  <origin xyz="0.055 0 0.03" rpy="0 0 -0.57004"/> <!-- -0.7854 rad ≈ -45° -->
</joint>

<gazebo reference="tof_sensor_right_link">
  <sensor name="tof_right" type="ray">
    <pose>0.03 0 0 0 0 0</pose>
    <visualize>true</visualize>
    <update_rate>10</update_rate>
    <ray>
      <scan>
        <horizontal>
          <samples>1</samples>
          <resolution>1</resolution>
          <min_angle>0</min_angle>
          <max_angle>0</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.01</min>
        <max>2.0</max>
        <resolution>0.01</resolution>
      </range>
    </ray>
    <plugin name="gazebo_ros_ray_sensor_right" filename="libgazebo_ros_ray_sensor.so">
      <ros><argument>~/out:=tof_right</argument></ros>
      <output_type>sensor_msgs/LaserScan</output_type>
      <frame_name>tof_sensor_right_link</frame_name>
    </plugin>
  </sensor>
</gazebo>

<!-- imu sensor -->
<link name="imu_link">
  <visual>
    <geometry>
      <box size="0.02 0.02 0.002"/>
    </geometry>
    <material name="red">
      <color rgba="1 0 0 1"/> 
    </material>
  </visual>

  <collision>
    <geometry>
      <box size="0.03 0.03 0.01"/>
    </geometry>
  </collision>

  <inertial>
    <mass value="0.01"/>
    <origin xyz="0 0 0" />
    <inertia ixx="1e-5" ixy="0.0" ixz="0.0"
             iyy="1e-5" iyz="0.0"
             izz="1e-5"/>
  </inertial>
</link>


<joint name="imu_joint" type="fixed">
  <parent link="base_link"/>
  <child link="imu_link"/>
  <origin xyz="0 0 0.017" rpy="0 0 0"/>
</joint> 

<gazebo reference="imu_link">
    <gravity>true</gravity>
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <topic>__default_topic__</topic>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <topicName>imu</topicName>
        <bodyName>imu_link</bodyName>
        <updateRateHZ>10.0</updateRateHZ>
        <gaussianNoise>0.0</gaussianNoise>
        <xyzOffset>0 0 0</xyzOffset>
        <rpyOffset>0 0 0</rpyOffset>
        <frameName>imu_link</frameName>
        <initialOrientationAsReference>true</initialOrientationAsReference>
      </plugin>
      <pose>0 0 0 0 0 0</pose>
    </sensor>
  </gazebo>





    <gazebo>
        <plugin name='skid_steer_drive' filename='libgazebo_ros_diff_drive.so'>
        <ros>
          <!-- Set namespace -->
          <namespace></namespace>


        </ros>

        <!-- Update rate -->
        <update_rate>500</update_rate>

        <!-- Number of wheel pairs -->
        <num_wheel_pairs>2</num_wheel_pairs>

        <cmd_vel_timeout>0.1</cmd_vel_timeout>

        <!-- wheels0 -->
        <left_joint>front_left_wheel_joint</left_joint>
        <right_joint>front_right_wheel_joint</right_joint>

        <!-- wheels1-->
        <left_joint>back_left_wheel_joint</left_joint>
        <right_joint>back_right_wheel_joint</right_joint>

        <!-- kinematics -->
        <wheel_separation>0.053</wheel_separation>
        <wheel_separation>0.53</wheel_separation>

        <wheel_diameter>0.053</wheel_diameter>
        <wheel_diameter>0.053</wheel_diameter>

        <!-- limits -->
        <max_wheel_torque>20</max_wheel_torque>
        <max_wheel_acceleration>50.0</max_wheel_acceleration>

        <!-- output -->
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>true</publish_wheel_tf>

        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_link</robot_base_frame>

      </plugin>
    </gazebo>


</robot>
